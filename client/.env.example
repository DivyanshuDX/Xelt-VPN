# vpn-server host (x402 API on :4021, WireGuard on :51820). 127.0.0.1 for same-machine dev.
VITE_SERVER_IP=127.0.0.1

# x402 API base (optional override)
VITE_X402_API_URL=http://localhost:4021

# Session length in minutes
VITE_SESSION_MINUTES=5

# Casper Testnet — signing happens in the system browser via the Casper Wallet
# extension, so no chain RPC config is needed in the client.
