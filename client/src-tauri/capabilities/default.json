{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window — Vite dev server and VPN IPC",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://localhost:1420",
      "http://localhost:1420/**",
      "http://127.0.0.1:1420",
      "http://127.0.0.1:1420/**"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-start-dragging"
  ]
}
